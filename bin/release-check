#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null && pwd)"
repo_root="$(cd "$script_dir/.." >/dev/null && pwd)"
cd "$repo_root"

version="$(bin/release-version)"
expected="bon $version"

if [[ ! -f CHANGELOG.md ]]; then
  echo "error: CHANGELOG.md is required for releases" >&2
  exit 2
fi

if ! grep -Fq "## [$version]" CHANGELOG.md && ! grep -Fq "## [v$version]" CHANGELOG.md; then
  echo "error: CHANGELOG.md does not contain a section for $version" >&2
  exit 2
fi

mise run spec
mise run build

if [[ "$(bin/bon-release --version)" != "$expected" ]]; then
  echo "error: bin/bon-release --version does not match shard.yml version $version" >&2
  exit 2
fi

if [[ "$(bin/bon-release -v)" != "$expected" ]]; then
  echo "error: bin/bon-release -v does not match shard.yml version $version" >&2
  exit 2
fi

if current_tag="$(git describe --tags --exact-match HEAD 2>/dev/null)"; then
  if [[ "$current_tag" == v* && "${current_tag#v}" != "$version" ]]; then
    echo "error: current tag $current_tag does not match shard.yml version $version" >&2
    exit 2
  fi
fi

echo "Release checks passed for v$version."
